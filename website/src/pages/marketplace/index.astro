---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import marketplace from '../../data/marketplace.json';

const { tools, packs } = marketplace;
const base = import.meta.env.BASE_URL;

const categoryIcons: Record<string, string> = {
  CLI: '⌨', Cloud: '☁', Containers: '⬢', Database: '▤', IaC: '▣',
  Language: '◆', Security: '⛨', Shell: '⌘', VCS: '✦', AI: '★',
  PkgMgr: '▦', Observability: '◉', Testing: '◐', Network: '◯',
  Editor: '✎', Media: '▶', Other: '◇',
};

const categories = [...new Set(tools.map((t: any) => t.category))].sort();
const categoryCountMap = tools.reduce((acc: Record<string, number>, t: any) => {
  acc[t.category] = (acc[t.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

function pmBadges(packages: Record<string, string>) {
  const labels: Record<string, string> = {
    brew: 'brew', winget: 'winget', scoop: 'scoop',
    choco: 'choco', apt: 'apt', snap: 'snap', npm: 'npm',
  };
  return Object.keys(packages).filter(k => k in labels).map(k => labels[k]);
}

function formatStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}
---

<Layout title="Marketplace — klim" description={`Browse ${tools.length} curated developer tools and ${packs.length} packs for klim.`}>
  <Header />

  <main class="pb-20">

    <!-- Hero (editorial) -->
    <section class="mx-auto max-w-6xl px-6 pt-16 pb-12">
      <p class="mono-label">§ — Marketplace</p>
      <h1 class="display mt-3 text-[2.6rem] sm:text-[3.4rem]" style="color: var(--fg);">
        {tools.length} tools.
        <span class="display-italic" style="color: var(--accent);">{packs.length} packs.</span>
      </h1>
      <p class="mt-5 max-w-2xl text-[1.05rem] leading-[1.6]" style="color: var(--fg-muted);">
        A curated catalog you can install, audit, share, and bake into a
        <span class="font-mono text-[0.95em]" style="color: var(--fg);">.klim.yaml</span> contract — without leaving the terminal.
      </p>
    </section>

    <!-- Tabs: Tools / Packs -->
    <section class="mx-auto max-w-6xl px-6">
      <div class="mb-8 flex items-center gap-1 rounded-full p-1 w-fit" role="tablist" style="border: 1px solid var(--rule); background: var(--bg-2);">
        <button
          id="tab-tools"
          role="tab"
          aria-selected="true"
          class="tab-btn rounded-full px-5 py-1.5 text-[0.88rem] font-medium transition-colors"
          style="background: var(--fg); color: var(--bg);"
        >
          Tools <span class="ml-1 text-[0.78rem] opacity-70">({tools.length})</span>
        </button>
        <button
          id="tab-packs"
          role="tab"
          aria-selected="false"
          class="tab-btn rounded-full px-5 py-1.5 text-[0.88rem] font-medium transition-colors"
          style="color: var(--fg-muted);"
        >
          Packs <span class="ml-1 text-[0.78rem] opacity-70">({packs.length})</span>
        </button>
      </div>

      <!-- Tools panel -->
      <div id="panel-tools">

        <!-- Search + count -->
        <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="relative flex-1 max-w-md">
            <input
              id="tool-search"
              type="text"
              placeholder="Search tools…"
              class="w-full rounded-full px-4 py-2.5 pl-10 text-[0.92rem] focus:outline-none"
              style="border: 1px solid var(--rule); background: var(--bg-2); color: var(--fg);"
            />
            <svg class="absolute left-3 top-3 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--fg-muted);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <div id="tool-count" class="text-[0.85rem]" style="color: var(--fg-muted);">
            Showing {tools.length} tools
          </div>
        </div>

        <!-- Category chips -->
        <div class="mb-10 flex flex-wrap gap-2">
          <button
            class="category-chip active rounded-full px-3 py-1 text-[0.78rem] font-medium transition-colors"
            data-category="all"
            style="border: 1px solid var(--accent); background: color-mix(in oklab, var(--accent) 12%, transparent); color: var(--accent);"
          >
            All ({tools.length})
          </button>
          {categories.map((cat: string) => (
            <button
              class="category-chip rounded-full px-3 py-1 text-[0.78rem] font-medium transition-colors"
              data-category={cat}
              style="border: 1px solid var(--rule); color: var(--fg-muted); background: transparent;"
            >
              <span class="opacity-70 mr-1">{categoryIcons[cat] || '◇'}</span>{cat} ({categoryCountMap[cat]})
            </button>
          ))}
        </div>

        <!-- Tool cards: editorial index cards (hairline border, no neon) -->
        <div id="tools-grid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {tools.map((tool: any) => (
            <a
              href={`${base}marketplace/tools/${tool.name}`}
              class="tool-card card group block rounded-[6px] p-4"
              style="border: 1px solid var(--rule); background: var(--bg-2);"
              data-name={tool.name}
              data-display={tool.display_name.toLowerCase()}
              data-category={tool.category}
              data-tags={tool.tags.join(',')}
              data-desc={tool.github_info?.description?.toLowerCase() || ''}
            >
              <div class="mb-1.5 flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <h3 class="display text-[1.1rem] truncate" style="color: var(--fg);">{tool.display_name}</h3>
                  <span class="font-mono text-[0.72rem]" style="color: var(--fg-muted);">{tool.name}</span>
                </div>
                <span class="mono-label whitespace-nowrap" style="font-size: 0.66rem;">
                  {tool.category}
                </span>
              </div>

              {tool.github_info?.description && (
                <p class="mb-3 text-[0.85rem] leading-[1.5] line-clamp-2" style="color: var(--fg-muted);">{tool.github_info.description}</p>
              )}

              <div class="flex items-center gap-3 text-[0.74rem]" style="color: var(--fg-muted);">
                {tool.github_info?.stars > 0 && (
                  <span class="flex items-center gap-1"><span style="color: var(--marker);">★</span> {formatStars(tool.github_info.stars)}</span>
                )}
                {tool.github_info?.license && (<span>{tool.github_info.license}</span>)}
                {Object.keys(tool.packages).length > 0 && (
                  <span class="font-mono">{pmBadges(tool.packages).slice(0,3).join(' · ')}</span>
                )}
              </div>
            </a>
          ))}
        </div>

        <div id="no-results" class="hidden py-16 text-center" style="color: var(--fg-muted);">
          <p class="text-[1rem]">No tools match your search.</p>
          <p class="mt-2 text-[0.85rem]">Try a different keyword or category.</p>
        </div>
      </div>

      <!-- Packs panel -->
      <div id="panel-packs" class="hidden">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {packs.map((pack: any) => {
            const toolCount = pack.tools.length;
            return (
              <a
                href={`${base}marketplace/packs/${pack.name}`}
                class="card group block rounded-[6px] p-5"
                style="border: 1px solid var(--rule); background: var(--bg-2);"
              >
                <div class="mb-2 flex items-center gap-3">
                  <span class="text-[1.6rem] leading-none" style="color: var(--accent);">{pack.icon}</span>
                  <div>
                    <h3 class="display text-[1.15rem]" style="color: var(--fg);">{pack.display_name}</h3>
                    <span class="mono-label">{toolCount} tools</span>
                  </div>
                  <span class="ml-auto" style="color: var(--fg-muted);">→</span>
                </div>
                <p class="mb-4 text-[0.9rem] leading-[1.55]" style="color: var(--fg-muted);">{pack.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {pack.tools.map((t: string) => (
                    <span class="rounded px-1.5 py-0.5 font-mono text-[0.72rem]" style="border: 1px solid var(--rule); color: var(--fg);">{t}</span>
                  ))}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA: editorial pull-quote style -->
    <section class="mx-auto max-w-4xl px-6 mt-20">
      <div class="rounded-[6px] p-10 text-center" style="border: 1px solid var(--rule); background: var(--bg-2);">
        <h2 class="display text-[1.8rem]" style="color: var(--fg);">Bring the marketplace into your shell.</h2>
        <p class="filename mt-2">$ klim · then switch to the Marketplace tab</p>
        <div class="cli mt-6 mx-auto max-w-2xl px-5 py-4 text-left">
          <pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">curl -fsSL https://raw.githubusercontent.com/nassiharel/klim/main/install.sh | bash</span></code></pre>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Tab switching: pure visual toggle on the editorial tab pills.
  const tabTools = document.getElementById('tab-tools')!;
  const tabPacks = document.getElementById('tab-packs')!;
  const panelTools = document.getElementById('panel-tools')!;
  const panelPacks = document.getElementById('panel-packs')!;

  function setActive(tab: HTMLElement, panel: HTMLElement, otherTab: HTMLElement, otherPanel: HTMLElement) {
    tab.style.background = 'var(--fg)';
    tab.style.color = 'var(--bg)';
    tab.setAttribute('aria-selected', 'true');
    panel.classList.remove('hidden');

    otherTab.style.background = 'transparent';
    otherTab.style.color = 'var(--fg-muted)';
    otherTab.setAttribute('aria-selected', 'false');
    otherPanel.classList.add('hidden');
  }
  tabTools.addEventListener('click', () => setActive(tabTools, panelTools, tabPacks, panelPacks));
  tabPacks.addEventListener('click', () => setActive(tabPacks, panelPacks, tabTools, panelTools));

  // Filter & search.
  const searchInput   = document.getElementById('tool-search') as HTMLInputElement;
  const toolCards     = document.querySelectorAll('.tool-card') as NodeListOf<HTMLElement>;
  const categoryChips = document.querySelectorAll('.category-chip') as NodeListOf<HTMLElement>;
  const toolCount     = document.getElementById('tool-count')!;
  const noResults     = document.getElementById('no-results')!;
  const toolsGrid     = document.getElementById('tools-grid')!;
  let activeCategory  = 'all';

  function styleChip(chip: HTMLElement, active: boolean) {
    if (active) {
      chip.classList.add('active');
      chip.style.borderColor = 'var(--accent)';
      chip.style.color       = 'var(--accent)';
      chip.style.background  = 'color-mix(in oklab, var(--accent) 12%, transparent)';
    } else {
      chip.classList.remove('active');
      chip.style.borderColor = 'var(--rule)';
      chip.style.color       = 'var(--fg-muted)';
      chip.style.background  = 'transparent';
    }
  }

  function filterTools() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;
    toolCards.forEach(card => {
      const name     = card.dataset.display  || '';
      const rawName  = card.dataset.name     || '';
      const category = card.dataset.category || '';
      const tags     = card.dataset.tags     || '';
      const desc     = card.dataset.desc     || '';
      const matchesCategory = activeCategory === 'all' || category === activeCategory;
      const matchesSearch = !query ||
        name.includes(query) || rawName.includes(query) ||
        category.toLowerCase().includes(query) || tags.toLowerCase().includes(query) ||
        desc.includes(query);
      if (matchesCategory && matchesSearch) { card.classList.remove('hidden'); visible++; }
      else { card.classList.add('hidden'); }
    });
    toolCount.textContent = `Showing ${visible} tool${visible !== 1 ? 's' : ''}`;
    noResults.classList.toggle('hidden', visible > 0);
    toolsGrid.classList.toggle('hidden', visible === 0);
  }

  categoryChips.forEach(chip => {
    chip.addEventListener('click', () => {
      categoryChips.forEach(c => styleChip(c, false));
      styleChip(chip, true);
      activeCategory = chip.dataset.category || 'all';
      filterTools();
    });
  });

  searchInput.addEventListener('input', filterTools);
</script>
