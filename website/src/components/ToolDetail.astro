---
/*
 * ToolDetail — restyled to match the editorial paper-light system.
 * Uses theme tokens (--fg, --bg-2, --rule, --accent) so the dark-mode
 * toggle continues to work, and uses the .cli treatment for install
 * commands rather than green pills on slate.
 */
const { tool, installEntries } = Astro.props;
const base = import.meta.env.BASE_URL;
const info = tool.github_info;
const description = info ? info.description : '';
const stars = info ? info.stars : 0;
const forks = info ? info.forks : 0;
const license = info ? info.license : '';
const homepage = info ? info.homepage : '';
const topics = info && info.topics ? info.topics : [];
const archived = info ? info.archived : false;

function fmtStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}
---

<nav class="mb-10 text-[0.88rem]" style="color: var(--fg-muted);">
  <a href={`${base}marketplace`} class="hover:underline underline-offset-4" style="color: var(--fg);">← Marketplace</a>
</nav>

<!-- Header -->
<header class="mb-12 border-b pb-10" style="border-color: var(--rule);">
  <p class="mono-label">tool · {tool.category}</p>
  <h1 class="display mt-3 text-[2.6rem] sm:text-[3.2rem]" style="color: var(--fg);">
    {tool.display_name}
  </h1>
  <p class="mt-1 font-mono text-[0.95rem]" style="color: var(--fg-muted);">{tool.name}</p>
  {description && (
    <p class="mt-5 max-w-2xl text-[1.05rem] leading-[1.65]" style="color: var(--fg-muted);">{description}</p>
  )}

  <!-- Meta row -->
  <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-[0.85rem]" style="color: var(--fg-muted);">
    {stars > 0 && (<span><span style="color: var(--marker);">★</span> {fmtStars(stars)} stars</span>)}
    {forks > 0 && (<span>⑂ {fmtStars(forks)} forks</span>)}
    {license && (<span>{license}</span>)}
    {archived && (<span style="color: var(--marker);">⚠ archived upstream</span>)}
  </div>

  {tool.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tool.tags.map((tag: string) => (
        <span class="rounded-full px-2.5 py-0.5 text-[0.74rem]"
              style="border: 1px solid var(--rule); color: var(--fg-muted);">{tag}</span>
      ))}
    </div>
  )}

  <div class="mt-6 flex flex-wrap gap-3">
    {tool.github && (
      <a href={`https://github.com/${tool.github}`}
         class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[0.85rem] transition-colors"
         style="border: 1px solid var(--rule); color: var(--fg);"
         target="_blank" rel="noopener noreferrer">
        View on GitHub
      </a>
    )}
    {homepage && (
      <a href={homepage}
         class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[0.85rem] transition-colors"
         style="border: 1px solid var(--rule); color: var(--fg);"
         target="_blank" rel="noopener noreferrer">Homepage ↗</a>
    )}
  </div>
</header>

<!-- Install -->
{installEntries.length > 0 && (
  <section class="mb-12">
    <p class="mono-label">install</p>
    <h2 class="display mt-2 text-[1.5rem]" style="color: var(--fg);">Add to your environment</h2>
    <p class="filename mt-4 mb-2">$ klim install {tool.name}</p>
    <div class="cli px-5 py-4">
      <pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">klim install {tool.name}</span>
<span class="c-dim"># or pin a manager:</span>
<span class="c-prompt">$</span> <span class="c-fg">klim install {tool.name}</span> <span class="c-flag">--source brew</span></code></pre>
    </div>
    <p class="mt-3 text-[0.85rem]" style="color: var(--fg-muted);">
      klim picks the best native package manager for your OS, or you can set
      <code class="font-mono text-[0.92em]" style="color: var(--fg);">defaults.preferred_source</code> in config.
    </p>
  </section>
)}

<!-- Binaries -->
{tool.binary_names.length > 0 && (
  <section class="mb-12">
    <p class="mono-label">detected by</p>
    <h2 class="display mt-2 text-[1.5rem]" style="color: var(--fg);">Binaries on PATH</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {tool.binary_names.map((bin: string) => (
        <code class="rounded px-2.5 py-1 font-mono text-[0.82rem]"
              style="border: 1px solid var(--rule); background: var(--bg-2); color: var(--fg);">{bin}</code>
      ))}
    </div>
  </section>
)}

<!-- Topics -->
{topics.length > 0 && (
  <section class="mb-12">
    <p class="mono-label">topics</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {topics.map((topic: string) => (
        <a href={`https://github.com/topics/${topic}`}
           class="rounded-full px-2.5 py-0.5 text-[0.78rem] transition-colors hover:underline underline-offset-4"
           style="border: 1px solid var(--rule); color: var(--fg-muted);"
           target="_blank" rel="noopener noreferrer">{topic}</a>
      ))}
    </div>
  </section>
)}
