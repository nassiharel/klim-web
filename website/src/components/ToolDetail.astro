---
const { tool, installEntries } = Astro.props;
const base = import.meta.env.BASE_URL;
const info = tool.github_info;
const description = info ? info.description : '';
const stars = info ? info.stars : 0;
const forks = info ? info.forks : 0;
const license = info ? info.license : '';
const homepage = info ? info.homepage : '';
const topics = info && info.topics ? info.topics : [];
const archived = info ? info.archived : false;

function fmtStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}
---

<nav class="mb-8 text-sm text-gray-500">
  <a href={`${base}marketplace`} class="hover:text-green-400 transition-colors">&#8592; Marketplace</a>
</nav>

<!-- Header Card -->
<div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-8 mb-8">
  <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
    <div class="flex-1">
      <h1 class="text-3xl font-bold text-white">{tool.display_name}</h1>
      <span class="text-sm text-gray-500 font-mono">{tool.name}</span>
      {description && <p class="mt-4 text-lg text-gray-300 leading-relaxed">{description}</p>}
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-gray-800 px-3 py-1 text-xs font-medium text-gray-300">{tool.category}</span>
        {tool.tags.map((tag: string) => (
          <span class="rounded-full bg-green-500/10 border border-green-500/20 px-2.5 py-0.5 text-xs text-green-400">{tag}</span>
        ))}
      </div>
    </div>
    <div class="flex flex-row flex-wrap gap-4 md:flex-col md:items-end md:gap-3 md:min-w-[160px]">
      {stars > 0 && (
        <div class="flex items-center gap-2 rounded-lg bg-gray-800/80 px-3 py-2">
          <span class="text-yellow-400">&#11088;</span>
          <span class="text-sm font-semibold text-white">{fmtStars(stars)}</span>
          <span class="text-xs text-gray-500">stars</span>
        </div>
      )}
      {forks > 0 && (
        <div class="flex items-center gap-2 rounded-lg bg-gray-800/80 px-3 py-2">
          <span class="text-sm font-semibold text-white">{fmtStars(forks)}</span>
          <span class="text-xs text-gray-500">forks</span>
        </div>
      )}
      {license && (
        <div class="flex items-center gap-2 rounded-lg bg-gray-800/80 px-3 py-2">
          <span class="text-sm text-white">{license}</span>
        </div>
      )}
      {archived && (
        <div class="flex items-center gap-2 rounded-lg bg-yellow-500/10 border border-yellow-500/30 px-3 py-2">
          <span class="text-xs text-yellow-400 font-medium">Archived</span>
        </div>
      )}
    </div>
  </div>
  <div class="mt-6 flex flex-wrap gap-3">
    {tool.github && (
      <a href={`https://github.com/${tool.github}`} class="inline-flex items-center gap-2 rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 transition-all hover:border-gray-500 hover:text-white" target="_blank" rel="noopener noreferrer">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
      </a>
    )}
    {homepage && (
      <a href={homepage} class="inline-flex items-center gap-2 rounded-lg border border-gray-700 px-4 py-2 text-sm text-gray-300 transition-all hover:border-gray-500 hover:text-white" target="_blank" rel="noopener noreferrer">Homepage</a>
    )}
  </div>
</div>

<!-- Install -->
{installEntries.length > 0 && (
  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-8 mb-8">
    <h2 class="text-xl font-bold text-white mb-6">Add to your environment with klim</h2>
    <div class="overflow-hidden rounded-xl border border-green-500/30 bg-green-500/5 p-5">
      <p class="text-sm text-gray-400 mb-2">Let Klim route the install through the best native package manager:</p>
      <pre class="font-mono text-sm text-green-400">klim install {tool.name}</pre>
      <p class="mt-3 text-xs text-gray-500">Want a specific manager? Pass <code class="text-gray-300">--source brew</code> (or any of winget / choco / scoop / apt / snap / npm), or set <code class="text-gray-300">defaults.preferred_source</code> in <code class="text-gray-300">config.yaml</code>.</p>
    </div>
  </div>
)}

<!-- Binaries -->
{tool.binary_names.length > 0 && (
  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-8 mb-8">
    <h2 class="text-xl font-bold text-white mb-4">Detected Binaries</h2>
    <p class="text-sm text-gray-400 mb-4">klim detects this tool by finding these executables on your <code class="rounded bg-gray-800 px-1.5 py-0.5 text-green-400">PATH</code>:</p>
    <div class="flex flex-wrap gap-2">
      {tool.binary_names.map((bin: string) => (
        <code class="rounded-lg bg-gray-950 border border-gray-800 px-3 py-1.5 text-sm font-mono text-green-400">{bin}</code>
      ))}
    </div>
  </div>
)}

<!-- Topics -->
{topics.length > 0 && (
  <div class="rounded-2xl border border-gray-800 bg-gray-900/50 p-8 mb-8">
    <h2 class="text-xl font-bold text-white mb-4">GitHub Topics</h2>
    <div class="flex flex-wrap gap-2">
      {topics.map((topic: string) => (
        <a href={`https://github.com/topics/${topic}`} class="rounded-full bg-blue-500/10 border border-blue-500/20 px-3 py-1 text-xs text-blue-400 hover:bg-blue-500/20 transition-colors" target="_blank" rel="noopener noreferrer">{topic}</a>
      ))}
    </div>
  </div>
)}
