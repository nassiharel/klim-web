---
/*
 * PackDetail — paper-light editorial restyle. Same theme tokens as
 * ToolDetail; install command rendered as a .cli block.
 */
const { pack, resolvedTools } = Astro.props;
const base = import.meta.env.BASE_URL;

function fmtStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return String(n);
}

const totalStars = resolvedTools.reduce((sum: number, t: any) =>
  sum + (t.github_info?.stars || 0), 0);

const categories = [...new Set(resolvedTools.map((t: any) => t.category))];
---

<nav class="mb-10 text-[0.88rem]" style="color: var(--fg-muted);">
  <a href={`${base}marketplace`} class="hover:underline underline-offset-4" style="color: var(--fg);">← Marketplace</a>
</nav>

<!-- Header -->
<header class="mb-12 border-b pb-10" style="border-color: var(--rule);">
  <p class="mono-label">pack</p>
  <div class="mt-3 flex items-center gap-4">
    <span class="display text-[3rem] leading-none" style="color: var(--accent);">{pack.icon}</span>
    <div>
      <h1 class="display text-[2.6rem]" style="color: var(--fg);">{pack.display_name}</h1>
      <p class="font-mono text-[0.95rem]" style="color: var(--fg-muted);">{pack.name}</p>
    </div>
  </div>
  <p class="mt-5 max-w-2xl text-[1.05rem] leading-[1.65]" style="color: var(--fg-muted);">{pack.description}</p>

  <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-[0.85rem]" style="color: var(--fg-muted);">
    <span>{pack.tools.length} tools</span>
    {totalStars > 0 && (<span><span style="color: var(--marker);">★</span> {fmtStars(totalStars)} combined stars</span>)}
    {categories.map((cat: string) => (<span>{cat}</span>))}
  </div>
</header>

<!-- Install -->
<section class="mb-12">
  <p class="mono-label">install</p>
  <h2 class="display mt-2 text-[1.5rem]" style="color: var(--fg);">Apply this pack</h2>
  <p class="filename mt-4 mb-2">$ klim install --pack {pack.name}</p>
  <div class="cli px-5 py-4">
    <pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">klim install --pack {pack.name}</span>
<span class="c-dim">resolving {pack.tools.length} tools…</span>
<span class="c-dim">run</span> <span class="c-fg">klim plan</span> <span class="c-dim">to preview before apply</span></code></pre>
  </div>
</section>

<!-- Tools in pack -->
<section class="mb-12">
  <p class="mono-label">contents</p>
  <h2 class="display mt-2 text-[1.5rem]" style="color: var(--fg);">{resolvedTools.length} tools</h2>

  <ul class="mt-6 divide-y" style="border-color: var(--rule);">
    {resolvedTools.map((tool: any) => {
      const info = tool.github_info;
      const pmCount = Object.keys(tool.packages).length;
      return (
        <li style="border-top: 1px solid var(--rule);">
          <a href={`${base}marketplace/tools/${tool.name}`}
             class="group flex items-start gap-4 py-4 transition-colors">
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-3">
                <h3 class="display text-[1.15rem] group-hover:underline underline-offset-4" style="color: var(--fg);">{tool.display_name}</h3>
                <span class="font-mono text-[0.78rem]" style="color: var(--fg-muted);">{tool.name}</span>
              </div>
              {info?.description && (
                <p class="mt-1 text-[0.9rem] line-clamp-1" style="color: var(--fg-muted);">{info.description}</p>
              )}
              <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-[0.78rem]" style="color: var(--fg-muted);">
                <span>{tool.category}</span>
                {pmCount > 0 && <span>{pmCount} package managers</span>}
                {info?.stars > 0 && <span><span style="color: var(--marker);">★</span> {fmtStars(info.stars)}</span>}
                {info?.license && <span>{info.license}</span>}
              </div>
            </div>
            <span class="mt-2" style="color: var(--fg-muted);">→</span>
          </a>
        </li>
      );
    })}
  </ul>
</section>
