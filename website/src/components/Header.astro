---
const base = import.meta.env.BASE_URL;
const docsURL = process.env.KLIM_WEBSITE_DOCS_URL ?? `${base}docs/`;
const navLinks = [
  { label: 'Idea',        href: `${base}#idea` },
  { label: 'What it does', href: `${base}#what` },
  { label: 'Demo',        href: `${base}#demo` },
  { label: 'Install',     href: `${base}#install` },
  { label: 'Marketplace', href: `${base}marketplace` },
  { label: 'Docs',        href: docsURL },
];
---

<header class="sticky top-0 z-50 backdrop-blur" style="background-color: color-mix(in oklab, var(--bg) 86%, transparent); border-bottom: 1px solid var(--rule);">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">

    <!-- Wordmark: canonical klim mark (charcoal stem + brand-cyan chevron) + Geist wordmark. -->
    <a href={base} class="flex items-center gap-2.5" style="color: var(--fg);">
      <span class="brand-mark h-8 w-8 transition-transform group-hover:scale-105" aria-hidden="true"
            style="filter: drop-shadow(0 0 12px color-mix(in oklab, var(--accent) 35%, transparent));">
        <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="22" y="20" width="14" height="80" rx="3" fill="currentColor"/>
          <path d="M48 28 L82 60 L48 92" fill="none" stroke="#00c8e6" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="text-[1.2rem] font-semibold tracking-tight" style="letter-spacing: -0.02em;">klim</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[0.92rem] transition-colors hover:underline underline-offset-[6px] decoration-1"
          style="color: var(--fg-muted);"
          onmouseover="this.style.color='var(--fg)'"
          onmouseout="this.style.color='var(--fg-muted)'"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <!-- Theme toggle: switches data-theme between light/dark, persists choice. -->
      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle color theme"
        class="grid h-9 w-9 place-items-center rounded-full transition-colors"
        style="border: 1px solid var(--rule); color: var(--fg-muted);"
      >
        <svg class="h-4 w-4 theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
        </svg>
        <svg class="h-4 w-4 theme-icon-dark hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
        </svg>
      </button>

      <a
        href="https://github.com/nassiharel/klim"
        class="hidden sm:inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-[0.85rem] transition-colors"
        style="border: 1px solid var(--rule); color: var(--fg);"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.83 1.18 3.09 0 4.43-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" clip-rule="evenodd"/>
        </svg>
        GitHub
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const root = document.documentElement;
    const sync = () => {
      const t = root.getAttribute('data-theme');
      document.querySelectorAll('.theme-icon-light').forEach(el => el.classList.toggle('hidden', t === 'dark'));
      document.querySelectorAll('.theme-icon-dark').forEach(el  => el.classList.toggle('hidden', t !== 'dark'));
    };
    sync();
    btn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('klim-theme', next); } catch (e) {}
      sync();
    });
  })();
</script>
