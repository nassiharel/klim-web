---
const base = import.meta.env.BASE_URL;
// Docs URL is rendered as a path under the website's own base so the
// link follows the deployment: under github.io project pages this
// resolves to /<repo>/docs/, and once a custom domain is wired
// (klim.dev with base="/") it resolves to /docs/. The workflow can
// override via KLIM_WEBSITE_DOCS_URL when docs moves to a separate
// subdomain (e.g. https://docs.klim.dev).
const docsURL = process.env.KLIM_WEBSITE_DOCS_URL ?? `${base}docs/`;
// Internal hrefs use BASE_URL so they resolve correctly under both
// the custom-domain root (klim.dev) and the github.io project sub-
// path (/<repo>/). External links (GitHub) stay absolute.
const navLinks = [
  { label: 'Platform', href: `${base}#platform` },
  { label: 'Marketplace', href: `${base}marketplace` },
  { label: 'Install', href: `${base}#install` },
  { label: 'Docs', href: docsURL },
];
---

<header class="fixed top-0 z-50 w-full border-b border-slate-800/80 bg-slate-950/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={base} class="flex items-center gap-3 text-xl font-bold text-white">
      <span class="brand-mark h-9 w-9" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none">
          <rect width="32" height="32" rx="8" fill="#020617"></rect>
          <path d="M10 23V9" stroke="url(#header-mark)" stroke-width="4" stroke-linecap="round"></path>
          <path d="M10 16 22 9" stroke="url(#header-mark)" stroke-width="4" stroke-linecap="round"></path>
          <path d="M10 16 23 23" stroke="url(#header-mark)" stroke-width="4" stroke-linecap="round"></path>
          <circle cx="10" cy="9" r="2" fill="#ecfdf5"></circle>
          <circle cx="22" cy="9" r="2" fill="#ecfdf5"></circle>
          <circle cx="10" cy="16" r="2" fill="#ecfdf5"></circle>
          <circle cx="23" cy="23" r="2" fill="#ecfdf5"></circle>
          <defs>
            <linearGradient id="header-mark" x1="5" y1="4" x2="27" y2="28" gradientUnits="userSpaceOnUse">
              <stop stop-color="#34d399"></stop>
              <stop offset="0.55" stop-color="#22c55e"></stop>
              <stop offset="1" stop-color="#14b8a6"></stop>
            </linearGradient>
          </defs>
        </svg>
      </span>
      klim
    </a>
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm text-slate-400 transition-colors hover:text-white">
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/nassiharel/klim"
        class="text-sm text-slate-400 transition-colors hover:text-white"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
