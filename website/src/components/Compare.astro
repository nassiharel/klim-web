---
const rows = [
  {
    capability: 'Complete local tool inventory',
    pkgMgr: 'One manager at a time',
    verMgr: 'Managed runtimes only',
    scripts: 'Hand-rolled',
    agent: 'Re-discovers per prompt',
    klim: 'Unified environment map',
  },
  {
    capability: 'Project environment contract',
    pkgMgr: 'No',
    verMgr: 'Partial',
    scripts: 'Informal',
    agent: 'Prompt drift',
    klim: '.klim.yaml',
  },
  {
    capability: 'Cross-OS reproduction',
    pkgMgr: 'Per platform',
    verMgr: 'Limited',
    scripts: 'Fragile branches',
    agent: 'Non-deterministic',
    klim: 'Native PM mapping',
  },
  {
    capability: 'Machine-readable CI interface',
    pkgMgr: 'Inconsistent',
    verMgr: 'Partial',
    scripts: 'Custom',
    agent: 'Tokens per build',
    klim: 'Stable JSON + exit codes',
  },
  {
    capability: 'Security and compliance posture',
    pkgMgr: 'Package-local',
    verMgr: 'No',
    scripts: 'Manual',
    agent: 'Best effort',
    klim: 'Audit, score, SBOM',
  },
  {
    capability: 'Toolchain history and diff',
    pkgMgr: 'No',
    verMgr: 'No',
    scripts: 'Manual files',
    agent: 'Forgets sessions',
    klim: 'Trail + diff',
  },
  {
    capability: 'Agent-safe operations',
    pkgMgr: 'Low-level commands',
    verMgr: 'Low-level commands',
    scripts: 'Opaque',
    agent: 'Improvises',
    klim: 'Deterministic primitive',
  },
];
---

<section id="compare" class="py-20 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Klim is the layer above packages, scripts, and prompts
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-400">
        Package managers install packages. Scripts automate one workflow. Agents
        translate intent. Klim provides the environment contract and deterministic
        operations layer they can all rely on.
      </p>
    </div>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-slate-800">
            <th class="px-4 py-3 font-medium text-slate-400">Capability</th>
            <th class="px-4 py-3 font-medium text-slate-400">Package Managers</th>
            <th class="px-4 py-3 font-medium text-slate-400">Version Managers</th>
            <th class="px-4 py-3 font-medium text-slate-400">Ad-hoc Scripts</th>
            <th class="px-4 py-3 font-medium text-slate-400">AI Agent + Shell</th>
            <th class="px-4 py-3 font-medium text-emerald-300">klim</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-slate-800/50">
              <td class="px-4 py-3 text-slate-300">{row.capability}</td>
              <td class="px-4 py-3 text-slate-500">{row.pkgMgr}</td>
              <td class="px-4 py-3 text-slate-500">{row.verMgr}</td>
              <td class="px-4 py-3 text-slate-500">{row.scripts}</td>
              <td class="px-4 py-3 text-slate-500">{row.agent}</td>
              <td class="px-4 py-3 font-medium text-emerald-300">{row.klim}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
