---
/*
 * "The Idea" — three editorial paragraphs (Map · Standardize · Automate),
 * each paired with one tiny CLI snippet. Replaces the 6-pillar tile grid
 * with breathing room and a single concrete example per pillar.
 */
const stanzas = [
  {
    num: '01',
    head: 'Map',
    deck: 'Everything installed on this machine — version, source, binary path, supplier — collected into one local inventory you can actually grep.',
    cmd: 'klim tool list --output json',
    sample: '{ "tool":"terraform", "version":"1.8.2", "source":"brew", "path":"/opt/homebrew/bin/terraform" }',
  },
  {
    num: '02',
    head: 'Standardize',
    deck: 'Turn the inventory into a versioned contract. One file. The same contract drives onboarding, CI, devcontainers, and Dockerfiles — generated from one source.',
    cmd: 'klim project generate --target github-actions',
    sample: 'wrote .github/workflows/setup-toolchain.yml  ✓',
  },
  {
    num: '03',
    head: 'Automate',
    deck: 'Install · upgrade · audit · diff · restore · share. klim never reinvents package management; it delegates to brew, winget, apt, scoop, choco, snap, npm.',
    cmd: 'klim plan apply  &&  klim security score',
    sample: 'environment score: 94 / 100  ·  3 advisories  ·  0 blocked licenses',
  },
];
---

<section id="idea" class="border-t" style="border-color: var(--rule);">
  <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">

    <header class="mb-14 max-w-3xl">
      <p class="mono-label">§ 01 — The idea</p>
      <h2 class="display mt-3 text-[2.4rem] sm:text-[3rem]" style="color: var(--fg);">
        Three verbs.
        <span class="display-italic" style="color: var(--accent);">One binary.</span>
      </h2>
      <p class="mt-5 text-[1.05rem] leading-[1.6]" style="color: var(--fg-muted);">
        Most dev environments are a folk tradition — passed down in READMEs,
        Slack threads, and the dotfiles repo nobody dares to touch. klim makes
        the tradition <em>literal</em>.
      </p>
    </header>

    <ol class="divide-y" style="border-color: var(--rule); --tw-divide-opacity: 1;">
      {stanzas.map((s) => (
        <li class="grid gap-8 py-10 md:grid-cols-[7rem_minmax(0,1fr)_minmax(0,1fr)] md:gap-12" style="border-top: 1px solid var(--rule);">

          <!-- Index column (drop-cap-ish numbering, with glow) -->
          <div class="display numeral text-[4.5rem] leading-none">
            <span class="display-italic">{s.num}</span>
          </div>

          <!-- Prose column -->
          <div>
            <h3 class="display text-[1.9rem]" style="color: var(--fg);">{s.head}</h3>
            <p class="mt-3 text-[1.02rem] leading-[1.65]" style="color: var(--fg-muted);">{s.deck}</p>
          </div>

          <!-- Example column -->
          <div>
            <p class="filename mb-2">$ {s.cmd}</p>
            <div class="cli px-4 py-3 text-[0.78rem]">
              <span class="c-dim">{s.sample}</span>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- A single editorial pull-quote between sections, with a glowing ornament. -->
<section aria-hidden="false" class="relative border-y overflow-hidden" style="border-color: var(--rule);">
  <div aria-hidden="true" class="orb orb--accent -z-10" style="width: 480px; height: 480px; top: -160px; left: 50%; transform: translateX(-50%);"></div>

  <blockquote class="mx-auto max-w-4xl px-6 py-20 text-center">
    <div class="mb-6 text-[1.4rem] leading-none">
      <span class="ornament" aria-hidden="true">✦</span>
      <span class="ornament mx-3" aria-hidden="true" style="animation-delay: -1.8s;">✦</span>
      <span class="ornament" aria-hidden="true" style="animation-delay: -3.6s;">✦</span>
    </div>
    <p class="pullquote" style="color: var(--fg);">
      klim is the layer <span style="color: var(--accent);">above</span> packages,
      scripts, and prompts —
      the contract they can all read from.
    </p>
  </blockquote>
</section>
