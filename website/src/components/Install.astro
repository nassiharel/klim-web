---
---

<section id="install" class="py-20 md:py-32">
  <div class="mx-auto max-w-4xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Start with a local environment map
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Install Klim, run <code class="rounded bg-slate-800 px-1.5 py-0.5 text-sm text-emerald-300">klim</code>,
        and turn your current machine into a productivity booster for dev tools.
      </p>
    </div>

    <div class="mt-12 space-y-6">
      <!-- macOS / Linux -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">macOS / Linux — Quick Install</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>curl -fsSL https://raw.githubusercontent.com/nassiharel/klim/main/install.sh | bash</code></pre>
        </div>
      </div>

      <!-- Windows -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">Windows — PowerShell</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>irm https://raw.githubusercontent.com/nassiharel/klim/main/install.ps1 | iex</code></pre>
        </div>
      </div>

      <!-- Homebrew -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">Homebrew (macOS / Linux)</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>brew install nassiharel/tap/klim</code></pre>
        </div>
      </div>

      <!-- winget -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">winget (Windows)</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>winget install nassiharel.klim</code></pre>
          <p class="mt-3 text-xs text-slate-500">Each release auto-submits a PR to <code class="text-slate-300">microsoft/winget-pkgs</code>, published system-wide through winget.</p>
        </div>
      </div>

      <!-- Scoop -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">Scoop (Windows)</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>scoop bucket add nassiharel https://github.com/nassiharel/scoop-bucket
scoop install klim</code></pre>
        </div>
      </div>

      <!-- Go install -->
      <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-6 py-3">
          <h3 class="text-sm font-medium text-slate-300">Go Install</h3>
        </div>
        <div class="p-6">
          <pre class="overflow-x-auto rounded-lg bg-slate-950 p-4 font-mono text-sm text-emerald-300"><code>go install github.com/nassiharel/klim/cmd/klim@latest</code></pre>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      Pre-built binaries also available on
      <a href="https://github.com/nassiharel/klim/releases/latest" class="text-emerald-300 hover:text-emerald-200 underline" target="_blank" rel="noopener noreferrer">
        GitHub Releases
      </a>
      for macOS, Linux, and Windows (amd64 & arm64).
    </p>
  </div>
</section>
