---
/*
 * Install: collapsed from 6 stacked cards to a 3-tab block (macOS / Linux /
 * Windows) plus a "More ways to install" disclosure for Homebrew, Scoop,
 * Go install, and the releases page. Tabs are pure-CSS via :has + radio
 * inputs (no JS needed), styled in global.css.
 */
const base = import.meta.env.BASE_URL;
---

<section id="install" class="border-t" style="border-color: var(--rule);">
  <div class="mx-auto max-w-5xl px-6 py-20 md:py-28">

    <header class="mb-10 max-w-3xl">
      <p class="mono-label">§ 04 — Install</p>
      <h2 class="display mt-3 text-[2.4rem] sm:text-[3rem]" style="color: var(--fg);">
        One line. <span class="display-italic" style="color: var(--accent);">Pick your shell.</span>
      </h2>
      <p class="mt-5 leading-[1.6]" style="color: var(--fg-muted);">
        klim ships as a single binary. No runtime, no daemon, no account.
      </p>
    </header>

    <!--
      Tabbed install block. Radios are sibling-scoped so :has-less browsers
      still toggle via the global.css :checked selectors.
    -->
    <div class="install-tabs">
      <input class="tab-input" type="radio" name="install-os" id="tab-mac" checked />
      <input class="tab-input" type="radio" name="install-os" id="tab-linux" />
      <input class="tab-input" type="radio" name="install-os" id="tab-win" />

      <div class="tab-bar flex gap-1 rounded-full p-1 w-fit" style="border: 1px solid var(--rule); background: var(--bg-2);">
        <label for="tab-mac"   class="cursor-pointer rounded-full px-4 py-1.5 text-[0.85rem] transition-colors" style="color: var(--fg-muted);">macOS</label>
        <label for="tab-linux" class="cursor-pointer rounded-full px-4 py-1.5 text-[0.85rem] transition-colors" style="color: var(--fg-muted);">Linux</label>
        <label for="tab-win"   class="cursor-pointer rounded-full px-4 py-1.5 text-[0.85rem] transition-colors" style="color: var(--fg-muted);">Windows</label>
      </div>

      <div class="tab-panels mt-5">
        <div class="tab-panel" data-tab="mac">
          <p class="filename mb-2">~ $ — Homebrew (recommended)</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">brew install nassiharel/tap/klim</span></code></pre></div>
          <p class="filename mt-5 mb-2">or, via curl</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">curl -fsSL https://raw.githubusercontent.com/nassiharel/klim/main/install.sh | bash</span></code></pre></div>
        </div>

        <div class="tab-panel" data-tab="linux">
          <p class="filename mb-2">~ $ — curl (recommended)</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">curl -fsSL https://raw.githubusercontent.com/nassiharel/klim/main/install.sh | bash</span></code></pre></div>
          <p class="filename mt-5 mb-2">or, via Homebrew on Linux</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">brew install nassiharel/tap/klim</span></code></pre></div>
        </div>

        <div class="tab-panel" data-tab="win">
          <p class="filename mb-2">PS &gt; — winget (recommended)</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">&gt;</span> <span class="c-fg">winget install nassiharel.klim</span></code></pre></div>
          <p class="filename mt-5 mb-2">or, via PowerShell installer</p>
          <div class="cli px-5 py-4"><pre class="m-0"><code><span class="c-prompt">&gt;</span> <span class="c-fg">irm https://raw.githubusercontent.com/nassiharel/klim/main/install.ps1 | iex</span></code></pre></div>
        </div>
      </div>
    </div>

    <!-- More ways to install -->
    <details class="mt-10 group">
      <summary class="cursor-pointer text-[0.92rem] list-none flex items-center gap-2" style="color: var(--fg-muted);">
        <span class="font-mono text-[0.78rem] transition-transform group-open:rotate-90">▸</span>
        More ways to install (Scoop, Go, releases)
      </summary>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <div>
          <p class="filename mb-2">Scoop (Windows)</p>
          <div class="cli px-4 py-3 text-[0.82rem]"><pre class="m-0"><code><span class="c-prompt">&gt;</span> <span class="c-fg">scoop bucket add nassiharel</span>
   <span class="c-dim">https://github.com/nassiharel/scoop-bucket</span>
<span class="c-prompt">&gt;</span> <span class="c-fg">scoop install klim</span></code></pre></div>
        </div>
        <div>
          <p class="filename mb-2">Go install</p>
          <div class="cli px-4 py-3 text-[0.82rem]"><pre class="m-0"><code><span class="c-prompt">$</span> <span class="c-fg">go install github.com/nassiharel/klim/cmd/klim@latest</span></code></pre></div>
        </div>
      </div>
      <p class="mt-5 text-[0.85rem]" style="color: var(--fg-muted);">
        Pre-built binaries for macOS, Linux, and Windows (amd64 + arm64) on
        <a href="https://github.com/nassiharel/klim/releases/latest" class="underline" style="color: var(--accent);" target="_blank" rel="noopener noreferrer">GitHub Releases</a>.
      </p>
    </details>
  </div>
</section>
