---
const base = import.meta.env.BASE_URL;

const shots = [
  {
    src: 'examples/klim-installed-tui.png',
    title: 'Installed',
    caption: 'Every tool, every version, every install source — in one local inventory with category, platform, and tag filters.',
  },
  {
    src: 'examples/klim-dashboard-tui.png',
    title: 'Dashboard',
    caption: 'Environment score, tool coverage, GitHub highlights, package-manager mix, and category breakdown at a glance.',
  },
  {
    src: 'examples/klim-marketplace-tui.png',
    title: 'Marketplace',
    caption: '110+ curated tools, ranked by GitHub stars, with category, description, and policy / blocked indicators.',
  },
  {
    src: 'examples/klim-marketplace-packs-tui.png',
    title: 'Curated packs',
    caption: 'Bundles like Cloud Essentials, Kubernetes Starter, and Go Developer with completion progress.',
  },
  {
    src: 'examples/klim-marketplace-for-you-tui.png',
    title: 'For You',
    caption: 'Personalised recommendations ranked by overlap with what you already use.',
  },
  {
    src: 'examples/klim-project-tui.png',
    title: 'Project scan',
    caption: 'Detect required tools from .github/, go.mod, package.json, and friends. One Enter and .klim.yaml is written.',
  },
  {
    src: 'examples/klim-security-compliance-tui.png',
    title: 'Compliance',
    caption: 'Policy violations broken down by tool: disallowed sources, disallowed licenses, blocked tools, and missing required tools.',
  },
  {
    src: 'examples/klim-search-tui.png',
    title: 'Search',
    caption: 'Type to filter the marketplace by name, tag, or description without leaving the keyboard.',
  },
  {
    src: 'examples/klim-local-browser-view.png',
    title: 'Local browser',
    caption: 'Prefer a browser? `klim browser` serves the same data as a local web app — same actions, same recommendations.',
  },
];
---

<section id="screenshots" class="py-20 md:py-32 border-t border-slate-900/60">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        See klim in action
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-400">
        Nine TUI tabs and an optional local web view. Same data, same actions,
        same JSON — whichever surface you prefer.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {shots.map((shot) => (
        <figure class="group overflow-hidden rounded-xl border border-slate-800 bg-slate-900/50 transition-colors hover:border-emerald-500/40">
          <div class="aspect-[16/10] overflow-hidden bg-slate-950">
            <img
              src={`${base}${shot.src}`}
              alt={shot.title + ' — ' + shot.caption}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>
          <figcaption class="p-5">
            <h3 class="text-sm font-semibold text-emerald-300">{shot.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-slate-400">{shot.caption}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
