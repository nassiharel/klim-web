---
/*
 * Demo figure: keep the existing demo video but reframe it as an
 * editorial figure with a typeset caption and paper frame. No play-button
 * theatrics — just a labeled artifact.
 */
const videoUrl = 'https://github.com/nassiharel/klim/releases/download/v0.1.3/klim.mp4';
---

<section id="demo" class="border-t" style="border-color: var(--rule);">
  <div class="mx-auto max-w-5xl px-6 py-20 md:py-28">

    <header class="mb-10 max-w-3xl">
      <p class="mono-label">§ 03 — In motion</p>
      <h2 class="display mt-3 text-[2.4rem] sm:text-[3rem]" style="color: var(--fg);">
        Same data, <span class="display-italic" style="color: var(--accent);">different surface.</span>
      </h2>
      <p class="mt-5 leading-[1.6]" style="color: var(--fg-muted);">
        klim ships with an interactive TUI that mirrors what the CLI exposes —
        pick whichever fits the moment, the underlying data and operations are
        the same.
      </p>
    </header>

    <figure>
      <p class="filename mb-2">fig.&nbsp;2 — klim TUI, recorded session</p>
      <div class="overflow-hidden rounded-[4px]" style="border: 1px solid var(--rule); background: var(--bg-2);">
        <video
          controls
          preload="metadata"
          class="block w-full"
          poster=""
        >
          <source src={videoUrl} type="video/mp4" />
          <p>
            Your browser doesn't support HTML video.
            <a href={videoUrl} style="color: var(--accent);" class="underline">Download the demo</a>.
          </p>
        </video>
      </div>
      <figcaption class="mt-3 text-[0.85rem]" style="color: var(--fg-muted);">
        fig.&nbsp;2 — klim TUI, recorded session.
      </figcaption>
    </figure>
  </div>
</section>
