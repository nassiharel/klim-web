---
const videoUrl = 'https://github.com/nassiharel/klim/releases/download/v0.1.3/klim.mp4';
---

<section id="demo" class="py-20 md:py-32 border-t border-slate-900/60">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        See klim in action
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-400">
        Nine TUI tabs and an optional local web view. Same data, same actions,
        same JSON — whichever surface you prefer.
      </p>
    </div>

    <div class="mt-12 overflow-hidden rounded-xl border border-slate-800 bg-slate-950">
      <video
        controls
        preload="metadata"
        class="w-full"
        poster=""
      >
        <source src={videoUrl} type="video/mp4" />
        <p>Your browser doesn't support HTML video. <a href={videoUrl} class="text-emerald-400 underline">Download the demo</a>.</p>
      </video>
    </div>
  </div>
</section>
