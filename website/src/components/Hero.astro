---
const base = import.meta.env.BASE_URL;
const docsURL = process.env.KLIM_WEBSITE_DOCS_URL ?? `${base}docs/`;
---

<!--
  Hero: editorial display + warm sun-halo + two accent orbs. Real
  `klim plan show` block as the hero figure, framed with a soft accent glow.
-->
<section class="relative pt-14 pb-24 md:pt-24 md:pb-32 overflow-hidden">

  <!-- Atmosphere -->
  <div aria-hidden="true" class="halo-sun pointer-events-none absolute inset-x-0 top-0 -z-10 h-[560px]"></div>
  <div aria-hidden="true" class="orb orb--accent -z-10" style="width: 520px; height: 520px; top: 220px; left: -180px;"></div>
  <div aria-hidden="true" class="orb orb--sun -z-10" style="width: 420px; height: 420px; top: 320px; right: -120px;"></div>

  <!-- Corner brackets -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-12 mx-auto max-w-6xl px-6 hidden lg:block">
    <div class="flex justify-between" style="color: var(--rule);">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M2 2v8M2 2h8"/></svg>
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M22 2v8M22 2h-8"/></svg>
    </div>
  </div>

  <div class="relative mx-auto max-w-5xl px-6">

    <p class="mono-label rise rise-1">§ 00 — Productivity booster for dev tools</p>

    <h1 class="display mt-6 text-[3.4rem] sm:text-[5.2rem] lg:text-[6.6rem] rise rise-2" style="color: var(--fg);">
      Your toolchain,
      <br class="hidden sm:block" />
      <span class="display-italic" style="color: var(--accent);">finally written down.</span>
    </h1>

    <p class="mt-8 max-w-2xl text-[1.18rem] leading-[1.55] rise rise-3" style="color: var(--fg-muted);">
      <span style="color: var(--fg);">klim</span> maps the tools a project depends on,
      turns the answer into a <span class="font-mono text-[0.95em]" style="color: var(--fg);">.klim.yaml</span> contract,
      and runs install · audit · diff · upgrade · restore through the package
      managers your machine already <span class="marker" style="color: var(--ink);">trusts</span>.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-3 rise rise-4">
      <a
        href="#install"
        class="btn-glow inline-flex items-center gap-2 rounded-full px-5 py-3 text-[0.95rem] font-medium"
        style="background: var(--fg); color: var(--bg);"
      >
        <span class="font-mono">$</span> Get klim
      </a>
      <a
        href={docsURL}
        class="btn-ghost inline-flex items-center gap-2 rounded-full px-5 py-3 text-[0.95rem]"
        style="color: var(--fg); border: 1px solid var(--rule);"
      >
        Read the manual <span aria-hidden="true">→</span>
      </a>
      <span class="ml-1 text-[0.84rem]" style="color: var(--fg-muted);">
        Free · MIT · macOS · Linux · Windows
      </span>
    </div>

    <figure class="mt-16 rise rise-5">
      <figcaption class="filename mb-2 flex items-baseline justify-between">
        <span><span style="color: var(--accent);">~/projects/api</span> ⟩ klim plan show</span>
        <span class="hidden sm:inline">fig.&nbsp;1 — pending changes, grouped by manager</span>
      </figcaption>

      <div class="cli overflow-hidden">
        <div class="cli-chrome flex items-center justify-between px-4 py-2">
          <div class="flex gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full" style="background:#ff5f57;"></span>
            <span class="h-2.5 w-2.5 rounded-full" style="background:#febc2e;"></span>
            <span class="h-2.5 w-2.5 rounded-full" style="background:#28c840;"></span>
          </div>
          <span>zsh · klim 0.1.0</span>
        </div>

        <pre class="m-0 overflow-x-auto px-5 py-5"><code><span class="c-prompt">$</span> <span class="c-fg">klim plan show</span>

<span class="c-dim">Planning changes for</span> <span class="c-fg">.klim.yaml</span>  <span class="c-dim">(7 tools, 1 pack)</span>

  <span class="c-amber">~</span> kubectl     <span class="c-dim">1.29.4  →</span>  <span class="c-fg">1.30.1</span>   <span class="c-dim">brew    confidence</span> <span class="c-green">98%</span>  <span class="c-dim">low risk</span>
  <span class="c-amber">~</span> terraform   <span class="c-dim">1.6.6   →</span>  <span class="c-fg">1.8.2</span>    <span class="c-dim">brew    confidence</span> <span class="c-amber">71%</span>  <span class="c-dim">review changelog</span>
  <span class="c-green">+</span> sops        <span class="c-dim">     —  →</span>  <span class="c-fg">3.9.1</span>    <span class="c-dim">brew    confidence</span> <span class="c-green">99%</span>
  <span class="c-mag">✓</span> gh          <span class="c-dim">2.50.0</span>  <span class="c-dim">already matches contract</span>

<span class="c-dim">────────────────────────────────────────────────────────</span>
<span class="c-fg">summary</span>   <span class="c-green">+1</span>  <span class="c-amber">~2</span>  <span class="c-mag">·4</span>   <span class="c-dim">disk</span> 142 MB   <span class="c-dim">≈</span> 38s
<span class="c-dim">checkpoint</span> <span class="c-blue">pre-apply-2026-06-15T11:42Z</span> <span class="c-dim">will be captured</span>

<span class="c-prompt">$</span> <span class="c-fg">klim plan apply</span> <span class="c-flag">--yes</span>     <span class="c-dim"># or:</span> <span class="c-fg">klim plan diff teammate.yaml</span></code></pre>
      </div>
    </figure>
  </div>
</section>
