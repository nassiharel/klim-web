---
const base = import.meta.env.BASE_URL;
const docsURL = process.env.KLIM_WEBSITE_DOCS_URL ?? `${base}docs/`;
---

<footer class="border-t border-slate-800 py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-3">
        <span class="brand-mark h-7 w-7" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="#020617"></rect>
            <path d="M10 23V9M10 16 22 9M10 16 23 23" stroke="#22c55e" stroke-width="4" stroke-linecap="round"></path>
            <circle cx="10" cy="9" r="2" fill="#ecfdf5"></circle>
            <circle cx="22" cy="9" r="2" fill="#ecfdf5"></circle>
            <circle cx="10" cy="16" r="2" fill="#ecfdf5"></circle>
            <circle cx="23" cy="23" r="2" fill="#ecfdf5"></circle>
          </svg>
        </span>
        <span class="font-semibold text-white">klim</span>
        <span class="text-sm text-slate-500">— Reignite Dev Experience</span>
      </div>

      <div class="flex items-center gap-6 text-sm text-slate-400">
        <a href={docsURL} class="transition-colors hover:text-white">Docs</a>
        <a href="https://github.com/nassiharel/klim" class="transition-colors hover:text-white" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://github.com/nassiharel/klim/releases" class="transition-colors hover:text-white" target="_blank" rel="noopener noreferrer">Releases</a>
        <a href="https://github.com/nassiharel/klim/blob/main/LICENSE" class="transition-colors hover:text-white" target="_blank" rel="noopener noreferrer">MIT License</a>
      </div>
    </div>
  </div>
</footer>
