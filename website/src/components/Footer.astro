---
const base = import.meta.env.BASE_URL;
const docsURL = process.env.KLIM_WEBSITE_DOCS_URL ?? `${base}docs/`;
const year = new Date().getFullYear();
---

<footer class="border-t" style="border-color: var(--rule);">
  <div class="mx-auto max-w-6xl px-6 py-16">

    <!-- Colophon-style top row -->
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">

      <div>
        <a href={base} class="inline-flex items-center gap-2.5" style="color: var(--fg);">
          <span class="brand-mark h-8 w-8" aria-hidden="true">
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="22" y="20" width="14" height="80" rx="3" fill="currentColor"/>
              <path fill="none" stroke="#00c8e6" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"
                    d="M48 28 L82 60 L48 92">
                <animate attributeName="d" dur="2.4s" repeatCount="indefinite"
                         calcMode="spline" keyTimes="0;0.4;0.5;0.9;1"
                         keySplines="0.4 0 0.2 1; 0 0 1 1; 0.4 0 0.2 1; 0 0 1 1"
                         values="M48 28 L82 60 L48 92;
                                 M82 28 L48 60 L82 92;
                                 M82 28 L48 60 L82 92;
                                 M48 28 L82 60 L48 92;
                                 M48 28 L82 60 L48 92"/>
              </path>
            </svg>
          </span>
          <span class="text-[1.15rem] font-semibold" style="letter-spacing: -0.02em;">klim</span>
        </a>
        <p class="mt-4 max-w-sm text-[0.95rem] leading-[1.65]" style="color: var(--fg-muted);">
          A productivity booster for dev tools.
        </p>
      </div>

      <nav aria-label="Product">
        <p class="mono-label mb-3">Product</p>
        <ul class="space-y-2 text-[0.92rem]">
          <li><a href={`${base}#idea`}    class="hover:underline underline-offset-4" style="color: var(--fg);">Idea</a></li>
          <li><a href={`${base}#what`}    class="hover:underline underline-offset-4" style="color: var(--fg);">What it does</a></li>
          <li><a href={`${base}#demo`}    class="hover:underline underline-offset-4" style="color: var(--fg);">Demo</a></li>
          <li><a href={`${base}#install`} class="hover:underline underline-offset-4" style="color: var(--fg);">Install</a></li>
        </ul>
      </nav>

      <nav aria-label="Resources">
        <p class="mono-label mb-3">Resources</p>
        <ul class="space-y-2 text-[0.92rem]">
          <li><a href={docsURL}                                       class="hover:underline underline-offset-4" style="color: var(--fg);">Docs</a></li>
          <li><a href={`${base}marketplace`}                          class="hover:underline underline-offset-4" style="color: var(--fg);">Marketplace</a></li>
          <li><a href="https://github.com/nassiharel/klim/releases"   target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4" style="color: var(--fg);">Releases</a></li>
        </ul>
      </nav>

      <nav aria-label="Source">
        <p class="mono-label mb-3">Source</p>
        <ul class="space-y-2 text-[0.92rem]">
          <li><a href="https://github.com/nassiharel/klim"                   target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4" style="color: var(--fg);">GitHub</a></li>
          <li><a href="https://github.com/nassiharel/klim/issues"            target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4" style="color: var(--fg);">Issues</a></li>
          <li><a href="https://github.com/nassiharel/klim/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-4" style="color: var(--fg);">MIT License</a></li>
        </ul>
      </nav>
    </div>

    <!-- Colophon line -->
    <div class="mt-14 flex flex-col-reverse gap-4 border-t pt-6 text-[0.82rem] md:flex-row md:items-center md:justify-between" style="border-color: var(--rule); color: var(--fg-muted);">
      <p>
        © {year} klim · Set in <span class="italic" style="font-family: var(--font-display);">Instrument Serif</span> &amp; <span class="font-mono">Geist</span> · <span class="font-mono">JetBrains Mono</span>.
      </p>
      <p class="font-mono">
        <span aria-hidden="true">⌘</span> Reignite Dev Experience
      </p>
    </div>
  </div>
</footer>
